<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0A0A0A">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:background="#111111">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CYBERDECK NODE"
            android:textColor="#FFA500"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.2" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS: OFFLINE"
            android:textColor="#33FFA500"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Setup Logic UI -->
    <LinearLayout
        android:id="@+id/setupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ProgressBar
            android:id="@+id/setupProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:progressTint="#FFA500"/>

        <TextView
            android:id="@+id/setupText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready to initialize CyberDeck Core."
            android:textColor="#80FFA500"
            android:textSize="13sp"
            android:textAlignment="center"
            android:fontFamily="monospace"
            android:layout_marginVertical="16dp" />

        <Button
            android:id="@+id/btnStartServer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOOT LOCAL CORE"
            android:textColor="#000000"
            android:backgroundTint="#FFA500"
            android:fontFamily="monospace"
            android:paddingHorizontal="48dp" />
            
        <!-- <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will download approximately 30MB of runtime files and server core script."
            android:textColor="#4DFFA500"
            android:textSize="10sp"
            android:textAlignment="center"
            android:fontFamily="monospace"
            android:layout_marginTop="24dp" /> -->
    </LinearLayout>

    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:visibility="gone">
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />
    </FrameLayout>

</RelativeLayout>
